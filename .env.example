# WordPress & WooCommerce API configuration for Liora Jewelry
# Replace these with your real WordPress URL and credentials.

# Enable WordPress connection (set to true to fetch from WP instead of local JSON/mock)
VITE_USE_WORDPRESS=false

# Base WP URL (no trailing slash)
VITE_WP_API_URL=https://your-wordpress-site.com

# ===== Blog WordPress (SEO) =====
# Blog do WordPress tự render ở subdomain riêng. Web React chỉ link sang đây
# (header + CTA ở HomePage). Không fetch data runtime, không cần CORS.
# Đổi thành URL blog thật của bạn (không dấu gạch chéo cuối).
VITE_BLOG_URL=https://blog.liorajewelry.com

# WooCommerce REST API Keys (requires read/write or read credentials)
VITE_WC_CONSUMER_KEY=ck_XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX
VITE_WC_CONSUMER_SECRET=cs_XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# ===== Supabase (backend thật: sản phẩm, nội dung, tài khoản, đơn hàng) =====
# Tạo project miễn phí tại https://supabase.com → Project Settings → API
# Copy Project URL + anon public key vào 2 biến VITE_ dưới đây.

# Project URL (vd: https://xxxxxxxx.supabase.co)
VITE_SUPABASE_URL=

# Anon public key (an toàn cho frontend, đi kèm RLS)
VITE_SUPABASE_ANON_KEY=

# ----- CHỈ cho script seed (KHÔNG có tiền tố VITE_ → không bundle vào web) -----
# Service role key — tuyệt đối không để vào biến VITE_ (nó bypass RLS)
# Lấy ở Project Settings → API → service_role secret. Chỉ chạy `npm run seed-supabase` trên máy bạn.
SUPABASE_SERVICE_KEY=
